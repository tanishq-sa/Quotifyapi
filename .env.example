# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_EXPIRES_IN=7d
JWT_SECRET=your_minimum_32_character_jwt_secret_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Database Configuration
# Use SQLite locally out-of-the-box, or Postgres in production
DATABASE_URL=./database.sqlite
# POSTGRES_URL=postgres://user:password@host:port/database

# Admin Setup
ADMIN_EMAIL=your_email@example.com

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_BASIC_PLAN_ID=your_razorpay_basic_plan_id
RAZORPAY_PRO_PLAN_ID=your_razorpay_pro_plan_id
RAZORPAY_MONTHLY_PLAN_ID=your_razorpay_monthly_plan_id
RAZORPAY_YEARLY_PLAN_ID=your_razorpay_yearly_plan_id

# Email Configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# API Configuration
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_key_here
