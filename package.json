{
  "name": "quotifyapi",
  "version": "1.4.2",
  "description": "A beautiful, fast, and reliable quote API with comprehensive documentation",
  "main": "quotes.js",
  "bin": {
    "quotifyapi": "./cli.js"
  },
  "exports": {
    ".": "./quotes.js",
    "./server": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'Build complete - Express API ready for deployment'",
    "vercel-build": "echo 'Vercel build complete'",
    "docs": "echo 'Documentation available at https://quotify.dazzelr.tech'",
    "test": "jest --forceExit",
    "lint": "node --check server.js database.js database-postgres.js database-adapter.js quotes.js auth.js routes/*.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "express-slow-down": "^2.0.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "razorpay": "^2.9.6",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "api",
    "quotes",
    "express",
    "nodejs",
    "motivational",
    "inspirational",
    "wisdom",
    "love",
    "happiness",
    "sadness",
    "rest-api",
    "rate-limiting",
    "security",
    "quotify",
    "vercel"
  ],
  "author": "Tanishq Saini",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanishq-sa/Quotifyapi.git"
  },
  "bugs": {
    "url": "https://github.com/tanishq-sa/Quotifyapi/issues"
  },
  "homepage": "https://quotify.dazzelr.tech",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "server.js",
    "quotes.js",
    "cli.js",
    "quotes/",
    "public/",
    "README.md",
    "LICENSE"
  ]
}
